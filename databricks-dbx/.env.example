# Copy this file to .env and paste your PAT from:
# https://bolt-incentives.cloud.databricks.com → Settings → Developer → Access tokens
DATABRICKS_TOKEN=paste-your-token-here

# Jira (jira_auto_assign.py)
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=

# Optional UAM auto-assign tuning (UAM board: target the AM queue column only — check exact Status spelling in Jira):
# UAM_AUTO_ASSIGN_EXTRA_JQL=AND status = "AM Tickets"
# UAM_MAX_ISSUES=200
# JIRA_CUSTOM_FIELD_PROVIDER=customfield_12345
# UAM_FALLBACK_DISPLAY_NAME=Joanna Lizza Ayson
# UAM_FALLBACK_ACCOUNT_ID=
# UAM_DRY_RUN=0
# UAM_SKIP_UNKNOWN_ASSIGNEE=1
# UAM_MAX_TICKET_AGE_DAYS=30
# Кілька колонок (точні назви як у Issue → Status), напр. All Tickets + AM:
# UAM_STATUS_IN=All Tickets,AM TICKETS

# Route rules (Legal/FOP → Tetiana + SIMPLY_2PRIORITY; integration/Poster → Khrystyna; finance → Anna + MOPS TICKETS)
# UAM_ROUTE_RULES_ENABLED=1
# UAM_TRANSITION_ON_ROUTE=1
# UAM_STATUS_NAME_SIMPLY2=SIMPLY_2PRIORITY
# UAM_STATUS_NAME_MOPS=MOPS TICKETS
# UAM_ACCOUNT_ID_TETIANA=
# UAM_ACCOUNT_ID_ANNA=
# UAM_ACCOUNT_ID_KHRYSTYNA_INTEGRATION=
# UAM_DISPLAY_NAME_TETIANA=Tetiana Bondar
# UAM_DISPLAY_NAME_ANNA=Anna Zaritska
# UAM_DISPLAY_NAME_INTEGRATION=Khrystyna Berezna
