# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat ID (send /myid to the bot to find out)
TELEGRAM_ADMIN_CHAT_ID=

# Databricks PAT (optional — if not set, provider validation is skipped)
DATABRICKS_TOKEN=

# Webhook URL for Render.com (e.g. https://sticker-bot-xxxx.onrender.com)
# Leave empty for local polling mode
WEBHOOK_URL=
